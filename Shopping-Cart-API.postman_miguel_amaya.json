							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set(\"orderId\", json.id.toString());",
									"    pm.collectionVariables.set(\"orderTotal\", json.total.toString());",
									"    pm.test(\"Status 201 Created\", function () {",
									"        pm.response.to.have.status(201);",
									"    });",
									"    pm.test(\"Order ID and total saved\", function () {",
									"        pm.expect(json.id).to.be.a(\"number\");",
									"        pm.expect(json.total).to.be.a(\"number\");",
									"    });",
									"    pm.test(\"Order status is CONFIRMED\", function () {",
									"        pm.expect(json.status).to.eql(\"CONFIRMED\");",
									"    });",
									"}"
