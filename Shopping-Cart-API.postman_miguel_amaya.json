		{
			"name": "Payments",
			"description": "Procesamiento asíncrono de pagos con patrón Strategy.\nMétodos: CREDIT_CARD, DEBIT_CARD, CASH, BANK_TRANSFER.\nUsa orderId y orderTotal guardados por Checkout.",
			"item": [
				{
					"name": "Process payment (async)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 202) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set(\"paymentId\", json.id.toString());",
									"    pm.test(\"Status 202 Accepted\", function () {",
									"        pm.response.to.have.status(202);",
									"    });",
									"    pm.test(\"Payment ID saved\", function () {",
									"        pm.expect(json.id).to.be.a(\"number\");",
									"    });",
									"    pm.test(\"Payment status is PENDING\", function () {",
									"        pm.expect(json.status).to.eql(\"PENDING\");",
									"    });",
									"    pm.test(\"Location header present\", function () {",
									"        pm.response.to.have.header(\"Location\");",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Idempotency-Key",
								"value": "{{$guid}}",
								"description": "UUID único para evitar pagos duplicados (opcional pero recomendado)"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderId\": {{orderId}},\n    \"paymentMethod\": \"CREDIT_CARD\",\n    \"amount\": {{orderTotal}}\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/payments",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"payments"
							]
						},
						"description": "Envía pago para procesamiento asíncrono. Retorna 202 Accepted con status=PENDING.\nUsa orderId y orderTotal de la última orden.\nGuarda paymentId para Poll.\n\nMétodos de pago: CREDIT_CARD, DEBIT_CARD, CASH, BANK_TRANSFER."
					},
					"response": []
				},
				{
					"name": "Poll payment status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
